{
  "name": "Block Malformed Branch Names",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "~ALL"
      ],
      "exclude": [
        "refs/heads/main",
        "refs/heads/feature/*",
        "refs/heads/bugfix/*",
        "refs/heads/hotfix/*",
        "refs/heads/workflow/*",
        "refs/heads/workflows/*",
        "refs/heads/infrastructure/*",
        "refs/heads/infra/*",
        "refs/heads/ci/*",
        "refs/heads/architecture/*",
        "refs/heads/breaking/*",
        "refs/heads/docs/*",
        "refs/heads/chore/*",
        "refs/heads/codex-code/*",
        "refs/heads/copilot-code/*",
        "refs/heads/kiro-code/*",
        "refs/heads/codex-infra/*",
        "refs/heads/copilot-infra/*",
        "refs/heads/kiro-infra/*"
      ]
    }
  },
  "rules": [
    {
      "type": "creation"
    }
  ],
  "bypass_actors": []
}
