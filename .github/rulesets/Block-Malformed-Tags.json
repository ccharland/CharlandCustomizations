{
  "name": "Block-Malformed-Tags",
  "target": "tag",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [
        "refs/tags/v[0-9]*.[0-9]*.[0-9]*",
        "refs/tags/start/v[0-9]*.[0-9]*.[0-9]*",
        "refs/tags/feature/*"
      ],
      "include": [
        "~ALL"
      ]
    }
  },
  "rules": [
    {
      "type": "non_fast_forward"
    },
    {
      "type": "creation"
    }
  ],
  "bypass_actors": []
}
