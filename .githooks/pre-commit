#!/bin/sh

set -u

OVERRIDE="${CC_GIT_HOOK_ALLOW_PATH_POLICY_OVERRIDE:-}"

if [ "$OVERRIDE" = "1" ]; then
    echo "CC git path policy override enabled; skipping branch/path guard." >&2
    exit 0
fi

BRANCH="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)"
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMRD)"

APPROVED_PREFIX_TEXT="'feature/*', 'bugfix/*', 'hotfix/*', 'workflow/*', 'workflows/*', 'infrastructure/*', 'infra/*', 'ci/*', 'architecture/*', 'breaking/*', 'docs/*', 'chore/*', 'publish/*', 'codex-code/*', 'copilot-code/*', 'kiro-code/*', 'codex-infra/*', 'copilot-infra/*', and 'kiro-infra/*'"

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

classify_branch_policy() {
    case "$1" in
        feature/*|bugfix/*|hotfix/*|architecture/*|breaking/*|docs/*|chore/*|codex-code/*|copilot-code/*|kiro-code/*)
            POLICY_NAME='normal code branch'
            BLOCKED_PATTERN='^(\.github|\.githooks|\.kiro/settings|\.vscode|Scripts|tests/scripts)(/|$)'
            BLOCKED_PATHS='.github/, .githooks/, .kiro/settings/, .vscode/, Scripts/, and tests/scripts/'
            return 0
            ;;
        workflow/*|workflows/*|infrastructure/*|infra/*|ci/*|codex-infra/*|copilot-infra/*|kiro-infra/*)
            POLICY_NAME='workflow/infrastructure branch'
            BLOCKED_PATTERN='^(src|tests/src)(/|$)'
            BLOCKED_PATHS='src/ and tests/src/'
            return 0
            ;;
        publish/*)
            POLICY_NAME='publish/release branch'
            # Publish branches are restricted to release prep only: signing, manifest, changelog
            BLOCKED_PATTERN='^(\.github|\.githooks|\.kiro|\.vscode|Scripts|tests)(/|$)'
            BLOCKED_PATHS='.github/, .githooks/, .kiro/, .vscode/, Scripts/, and tests/'
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

if classify_branch_policy "$BRANCH"; then
    BLOCKED_FILES="$(printf '%s\n' "$STAGED_FILES" | grep -E "$BLOCKED_PATTERN" || true)"
else
    BRANCH_PREFIX="$(printf '%s' "$BRANCH" | cut -d/ -f1 | tr '[:upper:]' '[:lower:]')"
    echo "Commit blocked by CC git path policy." >&2
    echo "Branch '$BRANCH' has unrecognized prefix '$BRANCH_PREFIX/'." >&2
    echo "Allowed branch prefixes are: $APPROVED_PREFIX_TEXT." >&2
    echo >&2
    echo "All changes are blocked until the branch is renamed to an approved prefix." >&2
    exit 1
fi

if [ -n "$BLOCKED_FILES" ]; then
    echo "Commit blocked by CC git path policy." >&2
    echo "Branch '$BRANCH' is treated as a $POLICY_NAME." >&2
    echo "Do not commit $BLOCKED_PATHS changes on this branch type." >&2
    echo >&2
    echo "Blocked staged files:" >&2
    printf '%s\n' "$BLOCKED_FILES" >&2
    echo >&2
    echo "For a deliberate exception, rerun the commit with:" >&2
    echo "  CC_GIT_HOOK_ALLOW_PATH_POLICY_OVERRIDE=1 git commit ..." >&2
    exit 1
fi

exit 0
