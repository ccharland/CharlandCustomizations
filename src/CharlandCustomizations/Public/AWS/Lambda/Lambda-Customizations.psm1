<#
.SYNOPSIS
    Lambda-focused helper functions.
#>
Write-Verbose "Loading Lambda-Customizations.psm1"

. "$PSScriptRoot/../../../Private/New-AWSParamSplat.ps1"

function Get-CHARDeprecatedLMFunctionList {
    <#
    .SYNOPSIS
        Lists Lambda functions using deprecated runtimes.

    .DESCRIPTION
        Calls Get-LMFunctionList with the same common AWS parameters and filters
        the returned functions to only those running runtimes deprecated on or
        before the specified -Date. The internal runtime table includes both
        already-deprecated and scheduled-for-deprecation runtimes, so you can
        pass a future date to preview which functions will be affected.

    .PARAMETER Date
        Comparison date used to determine whether a runtime is deprecated.
        Defaults to the current date. Pass a future date to identify functions
        that will be running deprecated runtimes by that time.

    .PARAMETER Marker
        Pagination token for Get-LMFunctionList.

    .PARAMETER MaxItem
        Maximum number of functions to return from Get-LMFunctionList.

    .PARAMETER NoAutoIteration
        Disables automatic pagination for Get-LMFunctionList.

    .PARAMETER Region
        AWS region. If not specified, uses your default Region.

    .PARAMETER ProfileName
        AWS profile name. Optional.

    .PARAMETER AccessKey
        AWS access key. Optional.

    .PARAMETER SecretKey
        AWS secret key. Optional.

    .PARAMETER SessionToken
        AWS session token for temporary credentials. Optional.

    .PARAMETER Credential
        Pre-built AWS credential object. Optional.

    .PARAMETER ProfileLocation
        Custom credential file path. Optional.

    .PARAMETER EndpointUrl
        Custom AWS service endpoint URL. Optional.

    .INPUTS
        None. This function does not accept pipeline input.

    .OUTPUTS
        Amazon.Lambda.Model.FunctionConfiguration
        Returns function configuration objects for Lambda functions using
        deprecated runtimes.

    .EXAMPLE
        Get-CHARDeprecatedLMFunctionList -Region us-east-1

        Lists all Lambda functions in us-east-1 currently running deprecated runtimes.

    .EXAMPLE
        Get-CHARDeprecatedLMFunctionList -Date '2027-01-01' -Region us-west-2

        Previews which functions in us-west-2 will be on deprecated runtimes by
        January 2027, useful for planning upgrades ahead of schedule.

    .EXAMPLE
        Get-CHARDeprecatedLMFunctionList -ProfileName prod | Select-Object FunctionName, Runtime

        Returns just the name and runtime of deprecated functions in the prod profile.

    .NOTES
        Last updated June 2026
        Generated by Kiro using Auto, reviewed by ccharland

    .LINK
        https://docs.aws.amazon.com/lambda/latest/dg/lambda-runtimes.html
    #>
    [CmdletBinding()]
    [Diagnostics.CodeAnalysis.SuppressMessageAttribute(
        'PSAvoidUsingPlainTextForPassword', 'Credential',
        Justification = 'Credential is an AWS SDK credential object, not a PSCredential.')]
    param(
        [Parameter()]
        [datetime]$Date = (Get-Date),

        [Parameter()]
        [string]$Marker,

        [Parameter()]
        [int]$MaxItem,

        [Parameter()]
        [switch]$NoAutoIteration,

        # AWS common parameters
        [Parameter()]
        [string]$Region,

        [Parameter()]
        [string]$ProfileName,

        [Parameter()]
        [string]$AccessKey,

        [Parameter()]
        [string]$SecretKey,

        [Parameter()]
        [string]$SessionToken,

        [Parameter()]
        [object]$Credential,

        [Parameter()]
        [string]$ProfileLocation,

        [Parameter()]
        [string]$EndpointUrl
    )

    process {
        $awsParams = New-AWSParamSplat -BoundParameters $PSBoundParameters

        $listParams = @{}
        foreach ($paramName in @('Marker', 'MaxItem', 'NoAutoIteration')) {
            if ($PSBoundParameters.ContainsKey($paramName)) {
                $listParams[$paramName] = $PSBoundParameters[$paramName]
            }
        }

        # Deprecation dates sourced from AWS Lambda documentation:
        # https://docs.aws.amazon.com/lambda/latest/dg/lambda-runtimes.html
        # Last updated June 2026
        # Includes both already-deprecated and scheduled-for-deprecation runtimes.
        # The -Date parameter controls which runtimes are considered deprecated.
        $deprecatedRuntimeDates = @{
            # Already deprecated
            'nodejs'         = [datetime]'2016-08-30'
            'dotnetcore1.0'  = [datetime]'2019-06-27'
            'dotnetcore2.0'  = [datetime]'2019-05-30'
            'nodejs4.3-edge' = [datetime]'2020-03-05'
            'nodejs4.3'      = [datetime]'2020-03-05'
            'nodejs6.10'     = [datetime]'2019-08-12'
            'nodejs8.10'     = [datetime]'2020-03-06'
            'nodejs10.x'     = [datetime]'2021-07-30'
            'nodejs12.x'     = [datetime]'2023-03-31'
            'nodejs14.x'     = [datetime]'2023-12-04'
            'nodejs16.x'     = [datetime]'2024-06-12'
            'nodejs18.x'     = [datetime]'2025-09-01'
            'nodejs20.x'     = [datetime]'2026-04-30'
            'python2.7'      = [datetime]'2021-07-15'
            'python3.6'      = [datetime]'2022-07-18'
            'python3.7'      = [datetime]'2023-12-04'
            'python3.8'      = [datetime]'2024-10-14'
            'python3.9'      = [datetime]'2025-12-15'
            'ruby2.5'        = [datetime]'2021-07-30'
            'ruby2.7'        = [datetime]'2023-12-07'
            'ruby3.2'        = [datetime]'2026-03-31'
            'dotnetcore2.1'  = [datetime]'2022-01-05'
            'dotnetcore3.1'  = [datetime]'2023-04-03'
            'dotnet5.0'      = [datetime]'2022-05-10'
            'dotnet6'        = [datetime]'2024-12-20'
            'dotnet7'        = [datetime]'2024-05-14'
            'java8'          = [datetime]'2024-01-08'
            'go1.x'          = [datetime]'2024-01-08'
            'provided'       = [datetime]'2024-01-08'
            # Scheduled future deprecations
            'provided.al2'   = [datetime]'2026-07-31'
            'python3.10'     = [datetime]'2026-10-31'
            'dotnet8'        = [datetime]'2026-11-10'
            'dotnet9'        = [datetime]'2026-11-10'
            'nodejs22.x'     = [datetime]'2027-04-30'
            'ruby3.3'        = [datetime]'2027-03-31'
            'java8.al2'      = [datetime]'2027-06-30'
            'java11'         = [datetime]'2027-06-30'
            'java17'         = [datetime]'2027-06-30'
            'python3.11'     = [datetime]'2027-06-30'
            'nodejs24.x'     = [datetime]'2028-04-30'
            'ruby3.4'        = [datetime]'2028-03-31'
            'python3.12'     = [datetime]'2028-10-31'
            'dotnet10'       = [datetime]'2028-11-14'
            'python3.13'     = [datetime]'2029-06-30'
            'python3.14'     = [datetime]'2029-06-30'
            'java21'         = [datetime]'2029-06-30'
            'java25'         = [datetime]'2029-06-30'
            'ruby4.0'        = [datetime]'2029-03-31'
            'provided.al2023' = [datetime]'2029-06-30'
        }

        # Collect runtimes whose deprecation date has already passed
        $deprecatedRuntimes = $deprecatedRuntimeDates.Keys | Where-Object {
            $deprecatedRuntimeDates[$_] -le $Date
        }

        # Filter Lambda functions to those using a deprecated runtime
        $allFunctions = @(Get-LMFunctionList @listParams @awsParams)

        $allFunctions | Where-Object {
            -not [string]::IsNullOrWhiteSpace($_.Runtime) -and
            $_.Runtime.ToLowerInvariant() -in $deprecatedRuntimes
        }
    }
}

Export-ModuleMember -Function 'Get-CHARDeprecatedLMFunctionList'