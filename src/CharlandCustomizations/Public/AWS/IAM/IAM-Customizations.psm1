<#
.SYNOPSIS
    IAM-focused audit and search functions.

.DESCRIPTION
    Provides functions for auditing IAM policies and roles, including detection of
    deleted principals in policy statements and trust policies, and searching
    customer-managed policy statement content.

.NOTES
    Generated by Kiro using Auto, reviewed by ccharland
    Created: July 2026
#>
Write-Verbose "Loading IAM-Customizations.psm1"

. "$PSScriptRoot/../../../Private/New-AWSParamSplat.ps1"

function Find-CHARDeletedPrincipalPolicy {
    <#
    .SYNOPSIS
        Finds IAM policies that reference deleted principals.

    .DESCRIPTION
        Enumerates all customer-managed IAM policies and inspects each policy
        version's statements for Principal or Condition elements that reference
        principals no longer present in IAM (identifiable by their raw ARN
        containing a unique ID rather than a friendly path, e.g.
        'arn:aws:iam::123456789012:root' replaced by 'AIDACKCEVSQ6C2EXAMPLE').

        When a principal (user, role, group) is deleted from IAM, any policy
        statement that referenced it retains the principal's unique ID rather
        than the original ARN. This function detects those orphaned references
        by matching the pattern of AWS unique IDs (starting with AIDA, AROA,
        AGPA, AIPA, AKIA, ASCA, APKA).

    .PARAMETER Scope
        Limits the policies to enumerate. Valid values are 'All', 'AWS', or 'Local'.
        Defaults to 'Local' (customer-managed policies only).

    .PARAMETER Region
        AWS region. If not specified, uses your default region.

    .PARAMETER ProfileName
        AWS profile name. Optional.

    .PARAMETER AccessKey
        AWS access key. Optional.

    .PARAMETER SecretKey
        AWS secret key. Optional.

    .PARAMETER SessionToken
        AWS session token for temporary credentials. Optional.

    .PARAMETER Credential
        Pre-built AWS credential object. Optional.

    .PARAMETER ProfileLocation
        Custom credential file path. Optional.

    .PARAMETER EndpointUrl
        Custom AWS service endpoint URL. Optional.

    .INPUTS
        None. This function does not accept pipeline input.

    .OUTPUTS
        PSCustomObject with properties:
            PolicyName   - Name of the IAM policy
            PolicyArn    - ARN of the IAM policy
            VersionId    - The policy version where the deleted principal was found
            Statement    - The statement SID or index containing the reference
            DeletedPrincipal - The unique ID of the deleted principal found

    .EXAMPLE
        Find-CHARDeletedPrincipalPolicy -ProfileName prod

        Scans all customer-managed policies in the prod profile for deleted principal references.

    .EXAMPLE
        Find-CHARDeletedPrincipalPolicy -Scope All -Region us-east-1

        Scans all policies (including AWS-managed) in us-east-1 for deleted principal references.

    .NOTES
        Generated by Kiro using Auto, reviewed by ccharland
        Last updated: July 2026

    .LINK
        https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_identifiers.html
    #>
    [CmdletBinding()]
    [OutputType([PSCustomObject])]
    param(
        [Parameter()]
        [ValidateSet('All', 'AWS', 'Local')]
        [string]$Scope = 'Local',

        [Parameter()]
        [string]$Region,

        [Parameter()]
        [string]$ProfileName,

        [Parameter()]
        [string]$AccessKey,

        [Parameter()]
        [string]$SecretKey,

        [Parameter()]
        [string]$SessionToken,

        [Parameter()]
        [object]$Credential,

        [Parameter()]
        [string]$ProfileLocation,

        [Parameter()]
        [string]$EndpointUrl
    )

    begin {
        $awsParams = New-AWSParamSplat -BoundParameters $PSBoundParameters

        # AWS unique ID prefixes that indicate a deleted principal replaced the original ARN
        $deletedPrincipalPattern = '(AIDA|AROA|AGPA|AIPA|AKIA|ASCA|APKA)[A-Z0-9]{16,}'
    }

    process {
        Write-Verbose "Enumerating IAM policies with scope: $Scope"
        $policies = Get-IAMPolicyList -Scope $Scope @awsParams

        foreach ($policy in $policies) {
            Write-Verbose "Checking policy: $($policy.PolicyName)"

            try {
                $policyVersion = Get-IAMPolicyVersion -PolicyArn $policy.Arn -VersionId $policy.DefaultVersionId @awsParams
            }
            catch {
                Write-Warning "Failed to retrieve policy version for $($policy.PolicyName): $_"
                continue
            }

            # URL-decode the policy document
            $policyDocument = [System.Web.HttpUtility]::UrlDecode($policyVersion.Document)

            # Check for deleted principal unique IDs in the document
            $matches = [regex]::Matches($policyDocument, $deletedPrincipalPattern)

            if ($matches.Count -gt 0) {
                # Parse JSON to identify which statement contains the reference
                try {
                    $parsedDoc = $policyDocument | ConvertFrom-Json
                }
                catch {
                    Write-Warning "Failed to parse policy document for $($policy.PolicyName): $_"
                    continue
                }

                $statements = @($parsedDoc.Statement)
                for ($i = 0; $i -lt $statements.Count; $i++) {
                    $statementJson = $statements[$i] | ConvertTo-Json -Depth 10
                    $statementMatches = [regex]::Matches($statementJson, $deletedPrincipalPattern)

                    foreach ($match in $statementMatches) {
                        $statementId = if ($statements[$i].Sid) { $statements[$i].Sid } else { "Statement[$i]" }

                        [PSCustomObject]@{
                            PSTypeName       = 'AWS.IAM.DeletedPrincipalPolicy'
                            PolicyName       = $policy.PolicyName
                            PolicyArn        = $policy.Arn
                            VersionId        = $policy.DefaultVersionId
                            Statement        = $statementId
                            DeletedPrincipal = $match.Value
                        }
                    }
                }
            }
        }
    }
}

function Find-CHARDeletedPrincipalRole {
    <#
    .SYNOPSIS
        Finds IAM roles where the trust policy references deleted principals.

    .DESCRIPTION
        Enumerates all IAM roles and inspects each role's AssumeRolePolicyDocument
        (trust policy) for principal references that have been replaced by AWS
        unique IDs, indicating the original principal was deleted.

        When a principal referenced in a trust policy is deleted, AWS replaces
        the ARN with the principal's unique ID. This function detects those
        orphaned references by matching AWS unique ID patterns (AIDA, AROA,
        AGPA, AIPA, AKIA, ASCA, APKA prefixes).

    .PARAMETER PathPrefix
        Filter roles by path prefix. Defaults to '/' (all roles).

    .PARAMETER Region
        AWS region. If not specified, uses your default region.

    .PARAMETER ProfileName
        AWS profile name. Optional.

    .PARAMETER AccessKey
        AWS access key. Optional.

    .PARAMETER SecretKey
        AWS secret key. Optional.

    .PARAMETER SessionToken
        AWS session token for temporary credentials. Optional.

    .PARAMETER Credential
        Pre-built AWS credential object. Optional.

    .PARAMETER ProfileLocation
        Custom credential file path. Optional.

    .PARAMETER EndpointUrl
        Custom AWS service endpoint URL. Optional.

    .INPUTS
        None. This function does not accept pipeline input.

    .OUTPUTS
        PSCustomObject with properties:
            RoleName         - Name of the IAM role
            RoleArn          - ARN of the IAM role
            Statement        - The trust policy statement SID or index
            DeletedPrincipal - The unique ID of the deleted principal found

    .EXAMPLE
        Find-CHARDeletedPrincipalRole -ProfileName prod

        Scans all IAM roles in the prod profile for deleted principals in trust policies.

    .EXAMPLE
        Find-CHARDeletedPrincipalRole -PathPrefix '/application/' -Region us-east-1

        Scans roles under the /application/ path in us-east-1 for deleted principal references.

    .NOTES
        Generated by Kiro using Auto, reviewed by ccharland
        Last updated: July 2026

    .LINK
        https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_identifiers.html
    #>
    [CmdletBinding()]
    [OutputType([PSCustomObject])]
    param(
        [Parameter()]
        [string]$PathPrefix = '/',

        [Parameter()]
        [string]$Region,

        [Parameter()]
        [string]$ProfileName,

        [Parameter()]
        [string]$AccessKey,

        [Parameter()]
        [string]$SecretKey,

        [Parameter()]
        [string]$SessionToken,

        [Parameter()]
        [object]$Credential,

        [Parameter()]
        [string]$ProfileLocation,

        [Parameter()]
        [string]$EndpointUrl
    )

    begin {
        $awsParams = New-AWSParamSplat -BoundParameters $PSBoundParameters

        # AWS unique ID prefixes that indicate a deleted principal
        $deletedPrincipalPattern = '(AIDA|AROA|AGPA|AIPA|AKIA|ASCA|APKA)[A-Z0-9]{16,}'
    }

    process {
        Write-Verbose "Enumerating IAM roles with path prefix: $PathPrefix"
        $roles = Get-IAMRoleList -PathPrefix $PathPrefix @awsParams

        foreach ($role in $roles) {
            Write-Verbose "Checking role: $($role.RoleName)"

            # AssumeRolePolicyDocument is URL-encoded on the role object
            $trustDocument = [System.Web.HttpUtility]::UrlDecode($role.AssumeRolePolicyDocument)

            # Check for deleted principal unique IDs
            $matches = [regex]::Matches($trustDocument, $deletedPrincipalPattern)

            if ($matches.Count -gt 0) {
                try {
                    $parsedDoc = $trustDocument | ConvertFrom-Json
                }
                catch {
                    Write-Warning "Failed to parse trust policy for role $($role.RoleName): $_"
                    continue
                }

                $statements = @($parsedDoc.Statement)
                for ($i = 0; $i -lt $statements.Count; $i++) {
                    $statementJson = $statements[$i] | ConvertTo-Json -Depth 10
                    $statementMatches = [regex]::Matches($statementJson, $deletedPrincipalPattern)

                    foreach ($match in $statementMatches) {
                        $statementId = if ($statements[$i].Sid) { $statements[$i].Sid } else { "Statement[$i]" }

                        [PSCustomObject]@{
                            PSTypeName       = 'AWS.IAM.DeletedPrincipalRole'
                            RoleName         = $role.RoleName
                            RoleArn          = $role.Arn
                            Statement        = $statementId
                            DeletedPrincipal = $match.Value
                        }
                    }
                }
            }
        }
    }
}

function Search-CHARPolicyStatement {
    <#
    .SYNOPSIS
        Searches customer-managed IAM policy statements for a specified string.

    .DESCRIPTION
        Enumerates customer-managed IAM policies and searches each policy's
        default version document for a specified text string. This is useful for
        finding policies that reference specific resources, actions, conditions,
        or any arbitrary text within policy statements.

        The search is performed as a case-insensitive substring match against
        the full JSON policy document. Use -CaseSensitive to perform an exact
        case match instead.

    .PARAMETER SearchString
        The text string to search for within policy statements. Matched as a
        substring against the full JSON policy document.

    .PARAMETER CaseSensitive
        Performs a case-sensitive search. By default the search is case-insensitive.

    .PARAMETER Scope
        Limits the policies to enumerate. Valid values are 'All', 'AWS', or 'Local'.
        Defaults to 'Local' (customer-managed policies only).

    .PARAMETER Region
        AWS region. If not specified, uses your default region.

    .PARAMETER ProfileName
        AWS profile name. Optional.

    .PARAMETER AccessKey
        AWS access key. Optional.

    .PARAMETER SecretKey
        AWS secret key. Optional.

    .PARAMETER SessionToken
        AWS session token for temporary credentials. Optional.

    .PARAMETER Credential
        Pre-built AWS credential object. Optional.

    .PARAMETER ProfileLocation
        Custom credential file path. Optional.

    .PARAMETER EndpointUrl
        Custom AWS service endpoint URL. Optional.

    .INPUTS
        System.String
            You can pipe a search string to this function.

    .OUTPUTS
        PSCustomObject with properties:
            PolicyName      - Name of the IAM policy
            PolicyArn       - ARN of the IAM policy
            VersionId       - The policy version searched
            MatchedContent  - The line or context where the match was found

    .EXAMPLE
        Search-CHARPolicyStatement -SearchString 's3:GetObject' -ProfileName prod

        Finds all customer-managed policies in the prod profile that contain 's3:GetObject'.

    .EXAMPLE
        Search-CHARPolicyStatement -SearchString 'arn:aws:s3:::my-bucket' -Region us-east-1

        Finds policies referencing a specific S3 bucket ARN in us-east-1.

    .EXAMPLE
        'kms:Decrypt' | Search-CHARPolicyStatement -ProfileName dev

        Pipes a search string to find policies containing 'kms:Decrypt'.

    .EXAMPLE
        Search-CHARPolicyStatement -SearchString 'DENY' -CaseSensitive

        Performs a case-sensitive search for uppercase 'DENY' in policy documents.

    .NOTES
        Generated by Kiro using Auto, reviewed by ccharland
        Last updated: July 2026

    .LINK
        https://docs.aws.amazon.com/IAM/latest/UserGuide/access_policies.html
    #>
    [CmdletBinding()]
    [OutputType([PSCustomObject])]
    param(
        [Parameter(Mandatory, Position = 0, ValueFromPipeline)]
        [ValidateNotNullOrEmpty()]
        [string]$SearchString,

        [Parameter()]
        [switch]$CaseSensitive,

        [Parameter()]
        [ValidateSet('All', 'AWS', 'Local')]
        [string]$Scope = 'Local',

        [Parameter()]
        [string]$Region,

        [Parameter()]
        [string]$ProfileName,

        [Parameter()]
        [string]$AccessKey,

        [Parameter()]
        [string]$SecretKey,

        [Parameter()]
        [string]$SessionToken,

        [Parameter()]
        [object]$Credential,

        [Parameter()]
        [string]$ProfileLocation,

        [Parameter()]
        [string]$EndpointUrl
    )

    begin {
        $awsParams = New-AWSParamSplat -BoundParameters $PSBoundParameters
    }

    process {
        Write-Verbose "Searching IAM policies (scope: $Scope) for string: $SearchString"
        $policies = Get-IAMPolicyList -Scope $Scope @awsParams

        foreach ($policy in $policies) {
            Write-Verbose "Searching policy: $($policy.PolicyName)"

            try {
                $policyVersion = Get-IAMPolicyVersion -PolicyArn $policy.Arn -VersionId $policy.DefaultVersionId @awsParams
            }
            catch {
                Write-Warning "Failed to retrieve policy version for $($policy.PolicyName): $_"
                continue
            }

            # URL-decode the policy document
            $policyDocument = [System.Web.HttpUtility]::UrlDecode($policyVersion.Document)

            # Determine comparison type based on CaseSensitive switch
            $containsMatch = if ($CaseSensitive) {
                $policyDocument.Contains($SearchString)
            }
            else {
                $policyDocument.IndexOf($SearchString, [System.StringComparison]::OrdinalIgnoreCase) -ge 0
            }

            if ($containsMatch) {
                # Extract matching lines for context
                $lines = $policyDocument -split "`n"
                $matchedLines = foreach ($line in $lines) {
                    $lineMatch = if ($CaseSensitive) {
                        $line.Contains($SearchString)
                    }
                    else {
                        $line.IndexOf($SearchString, [System.StringComparison]::OrdinalIgnoreCase) -ge 0
                    }

                    if ($lineMatch) {
                        $line.Trim()
                    }
                }

                [PSCustomObject]@{
                    PSTypeName     = 'AWS.IAM.PolicySearchResult'
                    PolicyName     = $policy.PolicyName
                    PolicyArn      = $policy.Arn
                    VersionId      = $policy.DefaultVersionId
                    MatchedContent = ($matchedLines -join '; ')
                }
            }
        }
    }
}

